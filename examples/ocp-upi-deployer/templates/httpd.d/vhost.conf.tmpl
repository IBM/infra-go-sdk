# =============================================================================
# Apache Virtual Host Configuration for {{.Network.ClusterName}}.{{.Network.BaseDomain}}
# =============================================================================
# Generated by ocp-upi-deployer
# Cluster: {{.Network.ClusterName}}
# =============================================================================

# Cluster-specific directory alias
Alias /{{.Network.ClusterName}} {{.HelperNode.Services.HTTP.DocumentRoot}}/{{.Network.ClusterName}}

<Directory "{{.HelperNode.Services.HTTP.DocumentRoot}}/{{.Network.ClusterName}}">
    Options Indexes FollowSymLinks
    AllowOverride None
    Require all granted
    
    # Enable directory listing for easier debugging
    Options +Indexes
    
    # CORS headers for ignition files
    <FilesMatch "\.(ign|json)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, OPTIONS"
        Header set Access-Control-Allow-Headers "Content-Type"
    </FilesMatch>
</Directory>

# Ignition files directory
<Directory "{{.HelperNode.Services.HTTP.DocumentRoot}}/{{.Network.ClusterName}}/ignition">
    Options -Indexes +FollowSymLinks
    AllowOverride None
    Require all granted
    
    # Set correct MIME type for ignition files
    AddType application/json .ign
    
    # CORS headers
    Header set Access-Control-Allow-Origin "*"
</Directory>

# RHCOS images directory
<Directory "{{.HelperNode.Services.HTTP.DocumentRoot}}/{{.Network.ClusterName}}/images">
    Options +Indexes +FollowSymLinks
    AllowOverride None
    Require all granted
    
    # Enable range requests for large files
    EnableSendfile on
    EnableMMAP on
</Directory>

# Logging for this cluster
CustomLog logs/{{.Network.ClusterName}}-access.log combined
ErrorLog logs/{{.Network.ClusterName}}-error.log
LogLevel warn