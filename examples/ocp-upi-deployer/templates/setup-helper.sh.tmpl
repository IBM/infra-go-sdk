#!/bin/bash
# =============================================================================
# Helper Node Setup Script for OpenShift UPI Deployment
# =============================================================================
# This script configures the helper/bastion node with all required services:
# - dnsmasq (DHCP + DNS + TFTP) using modular flat configuration
# - HTTP server (for serving ignition configs and RHCOS images)
# - HAProxy (for load balancing API and ingress traffic)
# - NFS server (optional, for persistent storage)
#
# Generated by ocp-upi-deployer
# Cluster: {{.Network.ClusterName}}.{{.Network.BaseDomain}}
# =============================================================================

set -e
set -o pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration variables
CLUSTER_NAME="{{.Network.ClusterName}}"
BASE_DOMAIN="{{.Network.BaseDomain}}"
CLUSTER_FQDN="${CLUSTER_NAME}.${BASE_DOMAIN}"
OCP_VERSION="{{.OpenShift.Version}}"
HELPER_IP="{{.HelperNode.IP}}"
NETWORK_INTERFACE="{{.HelperNode.NetworkInterface}}"
HTTP_PORT="{{.HelperNode.Services.HTTP.Port}}"
HTTP_ROOT="{{.HelperNode.Services.HTTP.DocumentRoot}}"
TFTP_ROOT="{{.HelperNode.Services.Dnsmasq.TFTPRoot}}"
DNSMASQ_ENABLED="{{.HelperNode.Services.Dnsmasq.Enabled}}"
HAPROXY_ENABLED="{{.HelperNode.Services.HAProxy.Enabled}}"
NFS_ENABLED="{{.HelperNode.Services.NFS.Enabled}}"

# Paths - Flat structure for dnsmasq (no subdirectories)
DNSMASQ_CONF_DIR="/etc/dnsmasq.d"
DNSMASQ_MAIN_CONF="/etc/dnsmasq.conf"
CLUSTER_TFTP_DIR="${TFTP_ROOT}/${CLUSTER_NAME}"
CLUSTER_HTTP_DIR="${HTTP_ROOT}/${CLUSTER_NAME}"

# Cluster-specific config files (flat structure with cluster prefix)
CLUSTER_DHCP_CONF="${DNSMASQ_CONF_DIR}/${CLUSTER_NAME}-dhcp.conf"
CLUSTER_DNS_CONF="${DNSMASQ_CONF_DIR}/${CLUSTER_NAME}-dns.conf"
CLUSTER_TFTP_CONF="${DNSMASQ_CONF_DIR}/${CLUSTER_NAME}-tftp.conf"
GLOBAL_CONF="${DNSMASQ_CONF_DIR}/global.conf"

# Logging functions
log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

# Check if running as root
if [[ $EUID -ne 0 ]]; then
   log_error "This script must be run as root"
   exit 1
fi

log_info "========================================="
log_info "OpenShift Helper Node Setup"
log_info "========================================="
log_info "Cluster: ${CLUSTER_FQDN}"
log_info "OpenShift Version: ${OCP_VERSION}"
log_info "Helper IP: ${HELPER_IP}"
log_info "========================================="

# =============================================================================
# STEP 1: Install required packages
# =============================================================================
log_step "Installing required packages..."

# Detect OS
if [ -f /etc/redhat-release ]; then
    OS_VERSION=$(cat /etc/redhat-release | sed 's/.*release \([0-9]\).*/\1/')
    
    if [ "$OS_VERSION" -ge 9 ]; then
        log_info "Detected RHEL/CentOS 9+"
        dnf install -y dnsmasq httpd haproxy nfs-utils wget curl jq tar
    else
        log_info "Detected RHEL/CentOS 8 or earlier"
        yum install -y dnsmasq httpd haproxy nfs-utils wget curl jq tar
    fi
else
    log_error "Unsupported OS. This script requires RHEL/CentOS"
    exit 1
fi

# =============================================================================
# STEP 2: Configure firewall
# =============================================================================
log_step "Configuring firewall..."

if systemctl is-active --quiet firewalld; then
    # DNS
    firewall-cmd --permanent --add-service=dns
    
    # DHCP
    firewall-cmd --permanent --add-service=dhcp
    
    # TFTP
    firewall-cmd --permanent --add-service=tftp
    
    # HTTP
    firewall-cmd --permanent --add-port=${HTTP_PORT}/tcp
    
    # HAProxy (if enabled)
    if [ "$HAPROXY_ENABLED" = "true" ]; then
        firewall-cmd --permanent --add-port=6443/tcp  # API
        firewall-cmd --permanent --add-port=22623/tcp # Machine config
        firewall-cmd --permanent --add-port=80/tcp    # HTTP ingress
        firewall-cmd --permanent --add-port=443/tcp   # HTTPS ingress
        firewall-cmd --permanent --add-port=9000/tcp  # HAProxy stats
    fi
    
    # NFS (if enabled)
    if [ "$NFS_ENABLED" = "true" ]; then
        firewall-cmd --permanent --add-service=nfs
        firewall-cmd --permanent --add-service=rpc-bind
        firewall-cmd --permanent --add-service=mountd
    fi
    
    firewall-cmd --reload
    log_info "Firewall configured successfully"
else
    log_warn "Firewalld is not running. Skipping firewall configuration."
fi

# =============================================================================
# STEP 3: Configure dnsmasq (Modular Flat Configuration)
# =============================================================================
if [ "$DNSMASQ_ENABLED" = "true" ]; then
    log_step "Configuring dnsmasq with modular flat configuration..."
    
    # Create dnsmasq.d directory if it doesn't exist
    mkdir -p ${DNSMASQ_CONF_DIR}
    
    # Backup main dnsmasq.conf if it exists and hasn't been backed up
    if [ -f ${DNSMASQ_MAIN_CONF} ] && [ ! -f ${DNSMASQ_MAIN_CONF}.original ]; then
        cp ${DNSMASQ_MAIN_CONF} ${DNSMASQ_MAIN_CONF}.original
        log_info "Backed up original dnsmasq.conf"
    fi
    
    # Update main dnsmasq.conf to include conf-dir if not already present
    if ! grep -q "conf-dir=${DNSMASQ_CONF_DIR}" ${DNSMASQ_MAIN_CONF}; then
        echo "" >> ${DNSMASQ_MAIN_CONF}
        echo "# Include modular configurations (flat structure)" >> ${DNSMASQ_MAIN_CONF}
        echo "conf-dir=${DNSMASQ_CONF_DIR},*.conf" >> ${DNSMASQ_MAIN_CONF}
        log_info "Updated main dnsmasq.conf to include modular configs"
    fi
    
    # Deploy global configuration (only if it doesn't exist)
    if [ ! -f ${GLOBAL_CONF} ]; then
        if [ -f /tmp/dnsmasq-global.conf ]; then
            cp /tmp/dnsmasq-global.conf ${GLOBAL_CONF}
            log_info "Deployed global dnsmasq configuration"
        fi
    else
        log_info "Global dnsmasq configuration already exists, preserving it"
    fi
    
    # Deploy cluster-specific configurations (flat structure with cluster prefix)
    if [ -f /tmp/dnsmasq-dhcp.conf ]; then
        cp /tmp/dnsmasq-dhcp.conf ${CLUSTER_DHCP_CONF}
        log_info "Deployed DHCP configuration: ${CLUSTER_NAME}-dhcp.conf"
    fi
    
    if [ -f /tmp/dnsmasq-dns.conf ]; then
        cp /tmp/dnsmasq-dns.conf ${CLUSTER_DNS_CONF}
        log_info "Deployed DNS configuration: ${CLUSTER_NAME}-dns.conf"
    fi
    
    if [ -f /tmp/dnsmasq-tftp.conf ]; then
        cp /tmp/dnsmasq-tftp.conf ${CLUSTER_TFTP_CONF}
        log_info "Deployed TFTP configuration: ${CLUSTER_NAME}-tftp.conf"
    fi
    
    # Create cluster-specific TFTP directory
    mkdir -p ${CLUSTER_TFTP_DIR}/grub2
    mkdir -p ${CLUSTER_TFTP_DIR}/rhcos
    chmod -R 755 ${TFTP_ROOT}
    log_info "Created cluster-specific TFTP directories"
    
    # Test dnsmasq configuration
    log_info "Testing dnsmasq configuration..."
    if dnsmasq --test; then
        log_info "dnsmasq configuration is valid"
        
        # Enable and restart dnsmasq
        systemctl enable dnsmasq
        systemctl restart dnsmasq
        
        if systemctl is-active --quiet dnsmasq; then
            log_info "✓ dnsmasq configured and started successfully"
        else
            log_error "Failed to start dnsmasq"
            systemctl status dnsmasq
            exit 1
        fi
    else
        log_error "dnsmasq configuration test failed"
        exit 1
    fi
else
    log_info "dnsmasq is disabled, skipping configuration"
fi

# =============================================================================
# STEP 4: Configure HTTP server
# =============================================================================
log_step "Configuring HTTP server..."

# Create cluster-specific HTTP directory
mkdir -p ${CLUSTER_HTTP_DIR}/ignition
mkdir -p ${CLUSTER_HTTP_DIR}/images
chmod -R 755 ${HTTP_ROOT}
log_info "Created cluster-specific HTTP directories"

# Configure httpd to listen on custom port if needed
if [ "${HTTP_PORT}" != "80" ]; then
    if ! grep -q "Listen ${HTTP_PORT}" /etc/httpd/conf/httpd.conf; then
        sed -i "s/Listen 80/Listen ${HTTP_PORT}/" /etc/httpd/conf/httpd.conf
        log_info "Configured httpd to listen on port ${HTTP_PORT}"
    fi
fi

# Set SELinux context (if SELinux is enabled)
if command -v semanage &> /dev/null && getenforce | grep -q "Enforcing"; then
    semanage fcontext -a -t httpd_sys_content_t "${HTTP_ROOT}(/.*)?" 2>/dev/null || true
    restorecon -Rv ${HTTP_ROOT}
    log_info "Set SELinux context for HTTP root"
fi

# Enable and start httpd
systemctl enable httpd
systemctl restart httpd

if systemctl is-active --quiet httpd; then
    log_info "✓ HTTP server configured and started successfully"
    log_info "  Cluster URL: http://${HELPER_IP}:${HTTP_PORT}/${CLUSTER_NAME}/"
else
    log_error "Failed to start HTTP server"
    systemctl status httpd
    exit 1
fi

# =============================================================================
# STEP 5: Configure HAProxy (if enabled)
# =============================================================================
if [ "$HAPROXY_ENABLED" = "true" ]; then
    log_step "Configuring HAProxy..."
    
    # Backup original config
    if [ -f /etc/haproxy/haproxy.cfg ] && [ ! -f /etc/haproxy/haproxy.cfg.original ]; then
        cp /etc/haproxy/haproxy.cfg /etc/haproxy/haproxy.cfg.original
        log_info "Backed up original HAProxy configuration"
    fi
    
    # Deploy cluster-specific HAProxy config
    if [ -f /tmp/haproxy-${CLUSTER_NAME}.cfg ]; then
        cp /tmp/haproxy-${CLUSTER_NAME}.cfg /etc/haproxy/haproxy.cfg
        
        # Test HAProxy configuration
        if haproxy -c -f /etc/haproxy/haproxy.cfg; then
            log_info "HAProxy configuration is valid"
            
            # Enable and start HAProxy
            systemctl enable haproxy
            systemctl restart haproxy
            
            if systemctl is-active --quiet haproxy; then
                log_info "✓ HAProxy configured and started successfully"
                log_info "  Stats URL: http://${HELPER_IP}:9000/stats"
            else
                log_error "Failed to start HAProxy"
                systemctl status haproxy
                exit 1
            fi
        else
            log_error "HAProxy configuration test failed"
            exit 1
        fi
    else
        log_warn "HAProxy config not found at /tmp/haproxy-${CLUSTER_NAME}.cfg"
    fi
else
    log_info "HAProxy is disabled, skipping configuration"
fi

# =============================================================================
# STEP 6: Configure NFS (if enabled)
# =============================================================================
if [ "$NFS_ENABLED" = "true" ]; then
    log_step "Configuring NFS server..."
    
    # Create NFS export directory for this cluster
    NFS_EXPORT="{{.HelperNode.Services.NFS.ExportPath}}/${CLUSTER_NAME}"
    mkdir -p ${NFS_EXPORT}
    chmod 755 ${NFS_EXPORT}
    log_info "Created NFS export directory: ${NFS_EXPORT}"
    
    # Add export to /etc/exports if not already present
    if ! grep -q "${NFS_EXPORT}" /etc/exports; then
        echo "${NFS_EXPORT} *(rw,sync,no_root_squash,no_subtree_check)" >> /etc/exports
        log_info "Added NFS export for ${CLUSTER_NAME}"
    fi
    
    # Export filesystems
    exportfs -ra
    
    # Enable and start NFS
    systemctl enable nfs-server
    systemctl restart nfs-server
    
    if systemctl is-active --quiet nfs-server; then
        log_info "✓ NFS server configured and started successfully"
    else
        log_error "Failed to start NFS server"
        systemctl status nfs-server
        exit 1
    fi
else
    log_info "NFS is disabled, skipping configuration"
fi

# =============================================================================
# STEP 7: Download RHCOS images
# =============================================================================
log_step "Downloading RHCOS images for OpenShift ${OCP_VERSION}..."

RHCOS_BASE_URL="https://mirror.openshift.com/pub/openshift-v4/ppc64le/dependencies/rhcos/${OCP_VERSION}/latest"
RHCOS_DIR="${CLUSTER_HTTP_DIR}/images"

cd ${RHCOS_DIR}

# Download kernel
if [ ! -f rhcos-live-kernel-ppc64le ]; then
    log_info "Downloading RHCOS kernel..."
    wget -q --show-progress ${RHCOS_BASE_URL}/rhcos-live-kernel-ppc64le || log_warn "Failed to download kernel"
fi

# Download initramfs
if [ ! -f rhcos-live-initramfs.ppc64le.img ]; then
    log_info "Downloading RHCOS initramfs..."
    wget -q --show-progress ${RHCOS_BASE_URL}/rhcos-live-initramfs.ppc64le.img || log_warn "Failed to download initramfs"
fi

# Download rootfs
if [ ! -f rhcos-live-rootfs.ppc64le.img ]; then
    log_info "Downloading RHCOS rootfs..."
    wget -q --show-progress ${RHCOS_BASE_URL}/rhcos-live-rootfs.ppc64le.img || log_warn "Failed to download rootfs"
fi

log_info "RHCOS images downloaded successfully"

# =============================================================================
# STEP 8: Setup PXE boot files
# =============================================================================
log_step "Setting up PXE boot configuration..."

# Copy grub EFI bootloader for PowerPC
if [ -f /boot/efi/EFI/redhat/grubppc64.efi ]; then
    cp /boot/efi/EFI/redhat/grubppc64.efi ${CLUSTER_TFTP_DIR}/grub2/
    log_info "Copied grubppc64.efi from RHEL"
elif [ -f /boot/efi/EFI/centos/grubppc64.efi ]; then
    cp /boot/efi/EFI/centos/grubppc64.efi ${CLUSTER_TFTP_DIR}/grub2/
    log_info "Copied grubppc64.efi from CentOS"
else
    log_warn "grubppc64.efi not found, you may need to copy it manually to ${CLUSTER_TFTP_DIR}/grub2/"
fi

log_info "PXE boot files configured"

# =============================================================================
# STEP 9: Create cluster info file
# =============================================================================
log_step "Creating cluster information file..."

cat > ${DNSMASQ_CONF_DIR}/${CLUSTER_NAME}-README.txt <<EOF
OpenShift Cluster: ${CLUSTER_FQDN}
Generated: $(date)
OpenShift Version: ${OCP_VERSION}

Configuration Files (Flat Structure):
- DHCP: ${CLUSTER_DHCP_CONF}
- DNS: ${CLUSTER_DNS_CONF}
- TFTP: ${CLUSTER_TFTP_CONF}

Directories:
- HTTP: ${CLUSTER_HTTP_DIR}
- TFTP: ${CLUSTER_TFTP_DIR}
- NFS: {{.HelperNode.Services.NFS.ExportPath}}/${CLUSTER_NAME}

To remove this cluster:
1. rm -f ${DNSMASQ_CONF_DIR}/${CLUSTER_NAME}-*.conf
2. rm -rf ${CLUSTER_HTTP_DIR}
3. rm -rf ${CLUSTER_TFTP_DIR}
4. Remove NFS export from /etc/exports
5. systemctl reload dnsmasq

To list all configured clusters:
ls -1 ${DNSMASQ_CONF_DIR}/*-dhcp.conf | sed 's|.*/||; s|-dhcp.conf||'
EOF

log_info "Created cluster information file"

# =============================================================================
# STEP 10: Verify services
# =============================================================================
log_step "Verifying services..."

FAILED=0

if [ "$DNSMASQ_ENABLED" = "true" ]; then
    if ! systemctl is-active --quiet dnsmasq; then
        log_error "dnsmasq is not running"
        FAILED=1
    else
        log_info "✓ dnsmasq is running"
    fi
fi

if ! systemctl is-active --quiet httpd; then
    log_error "httpd is not running"
    FAILED=1
else
    log_info "✓ httpd is running"
fi

if [ "$HAPROXY_ENABLED" = "true" ]; then
    if ! systemctl is-active --quiet haproxy; then
        log_error "haproxy is not running"
        FAILED=1
    else
        log_info "✓ haproxy is running"
    fi
fi

if [ "$NFS_ENABLED" = "true" ]; then
    if ! systemctl is-active --quiet nfs-server; then
        log_error "nfs-server is not running"
        FAILED=1
    else
        log_info "✓ nfs-server is running"
    fi
fi

if [ $FAILED -eq 1 ]; then
    log_error "Some services failed to start. Please check the logs."
    exit 1
fi

# =============================================================================
# COMPLETION
# =============================================================================
log_info "========================================="
log_info "Helper node setup completed successfully!"
log_info "========================================="
log_info ""
log_info "Cluster: ${CLUSTER_FQDN}"
log_info ""
log_info "Services configured:"
log_info "  ✓ dnsmasq (DHCP + DNS + TFTP): ${DNSMASQ_ENABLED}"
log_info "  ✓ HTTP server: http://${HELPER_IP}:${HTTP_PORT}/${CLUSTER_NAME}/"
log_info "  ✓ HAProxy: ${HAPROXY_ENABLED}"
log_info "  ✓ NFS: ${NFS_ENABLED}"
log_info ""
log_info "Configuration files (flat structure):"
log_info "  - ${CLUSTER_NAME}-dhcp.conf"
log_info "  - ${CLUSTER_NAME}-dns.conf"
log_info "  - ${CLUSTER_NAME}-tftp.conf"
log_info ""
log_info "Directories:"
log_info "  - HTTP: ${CLUSTER_HTTP_DIR}/"
log_info "  - TFTP: ${CLUSTER_TFTP_DIR}/"
log_info ""
log_info "Next steps:"
log_info "  1. Copy ignition files to ${CLUSTER_HTTP_DIR}/ignition/"
log_info "  2. Generate PXE boot configurations"
log_info "  3. Power on cluster nodes"
log_info ""
log_info "To manage another cluster, run this script again with different cluster name"
log_info "All clusters will coexist using the flat configuration structure"
log_info ""

exit 0