# TFTP root directory for this cluster
# Note: Cluster-specific boot files should be in subdirectories
tftp-root={{.HelperNode.Services.Dnsmasq.TFTPRoot}}/{{.Network.ClusterName}}

# Disable TFTP secure mode for this cluster
tftp-no-blocksize

# Enable TFTP server (global setting, only needed once)
# enable-tftp

# =============================================================================
# PXE Boot Files
# =============================================================================

# Boot file paths are relative to tftp-root
# Structure: /var/lib/tftpboot/<cluster-name>/grub2/grubppc64.efi
#            /var/lib/tftpboot/<cluster-name>/grub2/grub.cfg
#            /var/lib/tftpboot/<cluster-name>/rhcos/

# Note: The actual boot file assignment is done in dhcp.conf
# This file just sets up the TFTP environment for the cluster