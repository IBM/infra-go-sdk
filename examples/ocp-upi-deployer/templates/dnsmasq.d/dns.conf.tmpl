# =============================================================================
# DNS Configuration for {{.Network.ClusterName}}.{{.Network.BaseDomain}}
# =============================================================================
# Generated by ocp-upi-deployer
# Cluster: {{.Network.ClusterName}}
# Domain: {{.Network.BaseDomain}}
# =============================================================================

# Local domain for this cluster
local=/{{.Network.ClusterName}}.{{.Network.BaseDomain}}/

# =============================================================================
# DNS A Records
# =============================================================================

{{if .HelperNode.IP}}
# Helper node
address=/{{.HelperNode.Hostname}}/{{.HelperNode.IP}}
address=/helper.{{.Network.ClusterName}}.{{.Network.BaseDomain}}/{{.HelperNode.IP}}
{{end}}

{{if .Bootstrap.IP}}
# Bootstrap node
address=/{{.Bootstrap.Hostname}}/{{.Bootstrap.IP}}
address=/bootstrap.{{.Network.ClusterName}}.{{.Network.BaseDomain}}/{{.Bootstrap.IP}}
{{end}}

{{range .Masters.Nodes}}
# Master node: {{.Name}}
address=/{{.Hostname}}/{{.IP}}
address=/{{.Name}}.{{$.Network.ClusterName}}.{{$.Network.BaseDomain}}/{{.IP}}
address=/etcd-{{.Name}}.{{$.Network.ClusterName}}.{{$.Network.BaseDomain}}/{{.IP}}
{{end}}

{{range .Workers.Nodes}}
# Worker node: {{.Name}}
address=/{{.Hostname}}/{{.IP}}
address=/{{.Name}}.{{$.Network.ClusterName}}.{{$.Network.BaseDomain}}/{{.IP}}
{{end}}

# =============================================================================
# OpenShift API Endpoints
# =============================================================================
# Using DNS round-robin for basic load distribution
# Note: This is NOT true load balancing (no health checks, session persistence)
# For production, consider using HAProxy or a hardware load balancer

{{if gt (len .Masters.Nodes) 0}}
# API endpoint - DNS round-robin across all masters
{{range .Masters.Nodes}}
address=/api.{{$.Network.ClusterName}}.{{$.Network.BaseDomain}}/{{.IP}}
{{end}}

# API-INT endpoint - DNS round-robin across all masters
{{range .Masters.Nodes}}
address=/api-int.{{$.Network.ClusterName}}.{{$.Network.BaseDomain}}/{{.IP}}
{{end}}
{{end}}

# =============================================================================
# OpenShift Wildcard Apps Domain
# =============================================================================
# Using DNS round-robin for ingress traffic distribution

{{if gt (len .Workers.Nodes) 0}}
# Wildcard apps domain - DNS round-robin across all workers
{{range .Workers.Nodes}}
address=/.apps.{{$.Network.ClusterName}}.{{$.Network.BaseDomain}}/{{.IP}}
{{end}}
{{else if gt (len .Masters.Nodes) 0}}
# Wildcard apps domain - DNS round-robin across masters (compact/SNO cluster)
{{range .Masters.Nodes}}
address=/.apps.{{$.Network.ClusterName}}.{{$.Network.BaseDomain}}/{{.IP}}
{{end}}
{{end}}

# =============================================================================
# etcd SRV Records
# =============================================================================

{{range $index, $master := .Masters.Nodes}}
# etcd SRV record for {{$master.Name}}
srv-host=_etcd-server-ssl._tcp.{{$.Network.ClusterName}}.{{$.Network.BaseDomain}},etcd-{{$master.Name}}.{{$.Network.ClusterName}}.{{$.Network.BaseDomain}},2380,0,10
{{end}}