# =============================================================================
# Global dnsmasq Configuration
# =============================================================================
# This file contains global settings that apply to all clusters
# Generated by ocp-upi-deployer (preserves existing settings)
# =============================================================================

# =============================================================================
# GENERAL SETTINGS
# =============================================================================

# Listen on specific interface only
interface={{.HelperNode.NetworkInterface}}
bind-interfaces

# Never forward plain names (without a dot or domain part)
domain-needed

# Never forward addresses in the non-routed address spaces
bogus-priv

# Don't read /etc/resolv.conf or any other file
no-resolv

# Don't poll /etc/resolv.conf for changes
no-poll

# Don't read /etc/hosts
no-hosts

# =============================================================================
# DNS FORWARDERS
# =============================================================================
# Upstream DNS servers for external name resolution

{{range .Network.DNSForwarders}}
server={{.}}
{{end}}

# =============================================================================
# TFTP GLOBAL SETTINGS
# =============================================================================

# Enable TFTP server (global setting)
enable-tftp

# Main TFTP root directory
tftp-root={{.HelperNode.Services.Dnsmasq.TFTPRoot}}

# =============================================================================
# LOGGING
# =============================================================================

# Log DHCP transactions
log-dhcp

# Log DNS queries
log-queries

# Log to file
log-facility=/var/log/dnsmasq.log

# =============================================================================
# CACHE SETTINGS
# =============================================================================

# Cache size (number of DNS entries)
cache-size=1000

# Negative caching TTL
neg-ttl=3600

# =============================================================================
# CLUSTER-SPECIFIC CONFIGURATIONS
# =============================================================================
# Individual cluster configurations are loaded from subdirectories
# Each cluster has its own directory under /etc/dnsmasq.d/<cluster-name>/
# containing dhcp.conf, dns.conf, and tftp.conf

# Include cluster-specific configurations
conf-dir=/etc/dnsmasq.d/,*.conf