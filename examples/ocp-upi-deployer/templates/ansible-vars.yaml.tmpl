# =============================================================================
# vars.yaml for ocp4-ai-powervm Ansible Playbook
# =============================================================================
# Generated by ocp-upi-deployer
# Cluster: {{.Network.ClusterName}}.{{.Network.BaseDomain}}
# 
# This file is used by the ocp4-ai-powervm ansible playbook to deploy
# OpenShift Container Platform on IBM Power Systems
#
# Reference: https://github.com/cs-zhang/ocp4-ai-powervm
# =============================================================================

# =============================================================================
# WORKING DIRECTORY
# =============================================================================
# Working directory for playbook operations
workdir: "/root/ocp4-workdir"

# =============================================================================
# DISK CONFIGURATION
# =============================================================================
# Disk where RHCOS will be installed on masters/workers
disk: {{.OpenShift.DiskDevice}}

# =============================================================================
# HELPER NODE CONFIGURATION
# =============================================================================
helper:
  name: "{{.HelperNode.Hostname}}"
  ipaddr: "{{.HelperNode.IP}}"
  networkifacename: "{{.HelperNode.NetworkInterface}}"

# =============================================================================
# DNS CONFIGURATION
# =============================================================================
dns:
  domain: "{{.Network.BaseDomain}}"
  clusterid: "{{.Network.ClusterName}}"
  forwarder1: "{{index .Network.DNSForwarders 0}}"
  {{if gt (len .Network.DNSForwarders) 1}}forwarder2: "{{index .Network.DNSForwarders 1}}"{{else}}forwarder2: "8.8.4.4"{{end}}

# =============================================================================
# DHCP CONFIGURATION
# =============================================================================
dhcp:
  router: "{{.Network.Gateway}}"
  bcast: "{{.Network.Broadcast}}"
  netmask: "{{.Network.Netmask}}"
  subnet: "{{.Network.NetworkCIDR}}"
  ipid: "{{.Network.Gateway | replace "1" "0"}}"  # Network ID
  netmaskid: "{{.Network.Netmask}}"

# =============================================================================
# BOOTSTRAP NODE CONFIGURATION
# =============================================================================
{{if .Bootstrap}}{{if .Bootstrap.IP}}
bootstrap:
  name: "{{.Bootstrap.Name}}"
  ipaddr: "{{.Bootstrap.IP}}"
  macaddr: "{{.Bootstrap.MACAddress}}"
  pvmcec: "{{.Bootstrap.SystemName}}"
  pvmlpar: "{{.Bootstrap.Name}}"
  disk: {{.OpenShift.DiskDevice}}
{{else}}
# Bootstrap node not configured (SNO or assisted installer mode)
{{end}}{{else}}
# Bootstrap node not configured (SNO or assisted installer mode)
{{end}}

# =============================================================================
# MASTER NODES CONFIGURATION
# =============================================================================
{{if .SNONode}}
# SNO Mode - Single master node
masters:
  - name: "{{.SNONode.Name}}"
    ipaddr: "{{.SNONode.IP}}"
    macaddr: "{{.SNONode.MACAddress}}"
    pvmcec: "{{.SNONode.SystemName}}"
    pvmlpar: "{{.SNONode.Name}}"
    disk: {{.OpenShift.DiskDevice}}
{{else}}{{if .Masters}}
# HA Mode - Multiple master nodes
masters:
{{range $index, $master := .Masters.Nodes}}
  - name: "{{$master.Name}}"
    ipaddr: "{{$master.IP}}"
    macaddr: "{{$master.MACAddress}}"
    pvmcec: "{{$master.SystemName}}"
    pvmlpar: "{{$master.Name}}"
    disk: {{$.OpenShift.DiskDevice}}
{{end}}
{{end}}{{end}}

# =============================================================================
# WORKER NODES CONFIGURATION
# =============================================================================
{{if .SNONode}}
# SNO Mode - No separate worker nodes
workers: []
{{else}}{{if .Workers}}{{if gt (len .Workers.Nodes) 0}}
workers:
{{range $index, $worker := .Workers.Nodes}}
  - name: "{{$worker.Name}}"
    ipaddr: "{{$worker.IP}}"
    macaddr: "{{$worker.MACAddress}}"
    pvmcec: "{{$worker.SystemName}}"
    pvmlpar: "{{$worker.Name}}"
    disk: {{$.OpenShift.DiskDevice}}
{{end}}
{{else}}
# No worker nodes configured (compact cluster)
workers: []
{{end}}{{else}}
# No worker nodes configured
workers: []
{{end}}{{end}}

# =============================================================================
# ADDITIONAL CONFIGURATION
# =============================================================================

# Force DNS to use the helper as the DNS server
forcedns: {{if .OpenShift.ForceDNS}}yes{{else}}no{{end}}

# NTP server configuration
{{if .Network.NTPServers}}
chronyconfig:
  enabled: true
  content:
{{range .Network.NTPServers}}    - server: {{.}}
{{end}}
{{else}}
chronyconfig:
  enabled: true
  content:
    - server: 0.rhel.pool.ntp.org
    - server: 1.rhel.pool.ntp.org
{{end}}

# OpenShift version
ocp_version: "{{.OpenShift.Version}}"

# Pull secret - using Ansible lookup to read from helper node
pull_secret: '{{ "{{" }} lookup("file", "/root/.openshift/pull-secret.json") | from_json | to_json {{ "}}" }}'

# SSH public key - using Ansible lookup to read from helper node
ssh_public_key: "{{ "{{" }} lookup('file', '~/.ssh/id_rsa.pub') {{ "}}" }}"

# =============================================================================
# RHCOS IMAGE URLS
# =============================================================================
# RHCOS images for PXE boot configuration
rhcos_arch: "{{.OpenShift.RHCOSArch}}"
rhcos_kernel: "{{.OpenShift.RHCOSImages.KernelURL}}"
rhcos_initramfs: "{{.OpenShift.RHCOSImages.InitramfsURL}}"
rhcos_rootfs: "{{.OpenShift.RHCOSImages.RootfsURL}}"

# =============================================================================
# OPENSHIFT CLIENT AND INSTALLER TARBALLS
# =============================================================================
# URL path to OCP clients download site
ocp_client_arch: "{{.OpenShift.OCPClientConfig.Arch}}"
ocp_base_url: "{{.OpenShift.OCPClientConfig.BaseURL}}"
ocp_client_base: "{{.OpenShift.OCPClientConfig.Base}}"
ocp_client_tag: "{{.OpenShift.OCPClientConfig.Tag}}"
ocp_client: "{{.OpenShift.OCPClientConfig.Client}}"
ocp_installer: "{{.OpenShift.OCPClientConfig.Installer}}"

# =============================================================================
# HMC ACCESS CONFIGURATION
# =============================================================================
# HMC access for netbooting LPARs (password-less SSH access required)
# The Ansible playbook will use this to power on and netboot LPARs via HMC
# Format: <hmc_user>@<hmc_ip>
pvm_hmc: "{{.HMC.Username}}@{{.HMC.IP}}"

# =============================================================================
# INSTALLATION TYPE
# =============================================================================
# Supported types: agent, assisted, sno, normal
install_type: {{.OpenShift.InstallType}}

# =============================================================================
# OPTIONAL: DOWNLOAD ARTIFACTS
# =============================================================================
# Some install types require downloading RHCOS and client to setup PXE
# For SNO and normal installations, set to true
# For Agent-based and assisted installations, set to false (extracts from ISO)
force_ocp_download: {{.OpenShift.ForceOCPDownload}}

# =============================================================================
# OPTIONAL: OCP CUSTOMIZATIONS
# =============================================================================
# Kernel options for RHCOS nodes
{{if .OpenShift.RHCOSKernelOptions}}rhcos_kernel_options: [{{range $i, $opt := .OpenShift.RHCOSKernelOptions}}{{if $i}}, {{end}}"{{$opt}}"{{end}}]{{else}}rhcos_kernel_options: []{{end}}

# Apply sysctl options via tuned operator
sysctl_tuned_options: {{.OpenShift.SysctlTunedOptions}}

# Deploy RMC daemonset on ppc64le nodes
powervm_rmc: {{.OpenShift.PowerVMRMC}}

# =============================================================================
# NOTES
# =============================================================================
# After generating this file:
# 1. Copy it to the helper node
# 2. Clone the ocp4-ai-powervm playbook on the helper node
# 3. Run the ansible playbook:
#    cd ocp4-ai-powervm
#    ansible-playbook -i inventory playbook.yml -e @vars.yaml
# =============================================================================