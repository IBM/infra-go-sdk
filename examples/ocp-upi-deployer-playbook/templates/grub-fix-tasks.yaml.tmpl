---
# =============================================================================
# Ansible Tasks: Fix GRUB Configuration for Multi-Node Support
# =============================================================================
# These tasks generate proper MAC-specific grub configs for each node
# Generated by ocp-upi-deployer
# =============================================================================

- name: Ensure grub directory exists
  file:
    path: /var/lib/tftpboot/boot/grub2/powerpc-ieee1275
    state: directory
    mode: '0755'

{{if .Bootstrap}}{{if .Bootstrap.IP}}
- name: Create grub config for bootstrap node
  copy:
    dest: "/var/lib/tftpboot/boot/grub2/powerpc-ieee1275/grub.cfg-01-{{.Bootstrap.MACAddress | lower | replace ":" "-"}}"
    content: |
      set default=0
      set timeout=1
      
      menuentry "CoreOS ({{.Bootstrap.Name}})" {
         echo "Loading kernel for {{.Bootstrap.Name}}"
         linux (tftp)/rhcos/kernel ip=dhcp console=tty0 console=ttyS0 console=hvc0,115200n8 rd.neednet=1 ignition.platform.id=metal ignition.firstboot coreos.live.rootfs_url=http://{{.HelperNode.IP}}:8000/install/rootfs.img ignition.config.url=http://{{.HelperNode.IP}}:8000/ignition/bootstrap.ign
      
         echo "Loading initrd"
         initrd (tftp)/rhcos/initramfs.img
      }
    mode: '0644'
{{end}}{{end}}

{{if .SNONode}}
- name: Create grub config for SNO master node
  copy:
    dest: "/var/lib/tftpboot/boot/grub2/powerpc-ieee1275/grub.cfg-01-{{.SNONode.MACAddress | lower | replace ":" "-"}}"
    content: |
      set default=0
      set timeout=1
      
      menuentry "CoreOS ({{.SNONode.Name}})" {
         echo "Loading kernel for {{.SNONode.Name}}"
         linux (tftp)/rhcos/kernel ip=dhcp console=tty0 console=ttyS0 console=hvc0,115200n8 rd.neednet=1 ignition.platform.id=metal ignition.firstboot coreos.live.rootfs_url=http://{{.HelperNode.IP}}:8000/install/rootfs.img ignition.config.url=http://{{.HelperNode.IP}}:8000/ignition/master-sno.ign
      
         echo "Loading initrd"
         initrd (tftp)/rhcos/initramfs.img
      }
    mode: '0644'
{{end}}

{{if .Masters}}{{range .Masters.Nodes}}
- name: Create grub config for master node {{.Name}}
  copy:
    dest: "/var/lib/tftpboot/boot/grub2/powerpc-ieee1275/grub.cfg-01-{{.MACAddress | lower | replace ":" "-"}}"
    content: |
      set default=0
      set timeout=1
      
      menuentry "CoreOS ({{.Name}})" {
         echo "Loading kernel for {{.Name}}"
         linux (tftp)/rhcos/kernel ip=dhcp console=tty0 console=ttyS0 console=hvc0,115200n8 rd.neednet=1 ignition.platform.id=metal ignition.firstboot coreos.live.rootfs_url=http://{{$.HelperNode.IP}}:8000/install/rootfs.img ignition.config.url=http://{{$.HelperNode.IP}}:8000/ignition/master.ign
      
         echo "Loading initrd"
         initrd (tftp)/rhcos/initramfs.img
      }
    mode: '0644'
{{end}}{{end}}

{{if .Workers}}{{range .Workers.Nodes}}
- name: Create grub config for worker node {{.Name}}
  copy:
    dest: "/var/lib/tftpboot/boot/grub2/powerpc-ieee1275/grub.cfg-01-{{.MACAddress | lower | replace ":" "-"}}"
    content: |
      set default=0
      set timeout=1
      
      menuentry "CoreOS ({{.Name}})" {
         echo "Loading kernel for {{.Name}}"
         linux (tftp)/rhcos/kernel ip=dhcp console=tty0 console=ttyS0 console=hvc0,115200n8 rd.neednet=1 ignition.platform.id=metal ignition.firstboot coreos.live.rootfs_url=http://{{$.HelperNode.IP}}:8000/install/rootfs.img ignition.config.url=http://{{$.HelperNode.IP}}:8000/ignition/worker.ign
      
         echo "Loading initrd"
         initrd (tftp)/rhcos/initramfs.img
      }
    mode: '0644'
{{end}}{{end}}

- name: Update main grub.cfg without MAC conditionals
  copy:
    dest: /var/lib/tftpboot/boot/grub2/grub.cfg
    content: |
      # Main grub config - fallback if MAC-specific config not found
      # MAC-specific configs: /var/lib/tftpboot/boot/grub2/powerpc-ieee1275/grub.cfg-01-{mac}
      set default=0
      set timeout=5
      
      menuentry "CoreOS (Default)" {
         echo "Loading kernel (fallback config)"
         linux (tftp)/rhcos/kernel ip=dhcp console=tty0 console=ttyS0 console=hvc0,115200n8 rd.neednet=1 ignition.platform.id=metal ignition.firstboot coreos.live.rootfs_url=http://{{.HelperNode.IP}}:8000/install/rootfs.img ignition.config.url=http://{{.HelperNode.IP}}:8000/ignition/master-sno.ign
      
         echo "Loading initrd"
         initrd (tftp)/rhcos/initramfs.img
      }
    mode: '0644'