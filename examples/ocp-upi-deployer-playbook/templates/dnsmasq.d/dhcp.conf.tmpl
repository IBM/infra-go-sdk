# =============================================================================
# DHCP Configuration for {{.Network.ClusterName}}.{{.Network.BaseDomain}}
# =============================================================================
# Generated by ocp-upi-deployer
# Cluster: {{.Network.ClusterName}}
# Domain: {{.Network.BaseDomain}}
# =============================================================================

# DHCP range for this cluster
dhcp-range={{.HelperNode.Services.Dnsmasq.DHCPRangeStart}},{{.HelperNode.Services.Dnsmasq.DHCPRangeEnd}},{{.Network.Netmask}},{{.HelperNode.Services.Dnsmasq.DHCPLeaseTime}}

# Gateway
dhcp-option=tag:{{.Network.ClusterName}},option:router,{{.Network.Gateway}}

# DNS server (helper node)
dhcp-option=tag:{{.Network.ClusterName}},option:dns-server,{{.HelperNode.IP}}

# Domain name
dhcp-option=tag:{{.Network.ClusterName}},option:domain-name,{{.Network.ClusterName}}.{{.Network.BaseDomain}}

# Broadcast address
dhcp-option=tag:{{.Network.ClusterName}},option:broadcast,{{.Network.Broadcast}}

# Netmask
dhcp-option=tag:{{.Network.ClusterName}},option:netmask,{{.Network.Netmask}}

# =============================================================================
# Static DHCP Reservations
# =============================================================================

{{if .Bootstrap.IP}}
# Bootstrap node
dhcp-host={{.Bootstrap.MACAddress}},{{.Bootstrap.IP}},{{.Bootstrap.Hostname}},set:{{.Network.ClusterName}},infinite
{{end}}

{{range .Masters.Nodes}}
# Master node: {{.Name}}
dhcp-host={{.MACAddress}},{{.IP}},{{.Hostname}},set:{{$.Network.ClusterName}},infinite
{{end}}

{{range .Workers.Nodes}}
# Worker node: {{.Name}}
dhcp-host={{.MACAddress}},{{.IP}},{{.Hostname}},set:{{$.Network.ClusterName}},infinite
{{end}}

# =============================================================================
# PXE Boot Configuration
# =============================================================================

# Match PowerPC EFI clients for this cluster
dhcp-match=set:efi-ppc64le-{{.Network.ClusterName}},option:client-arch,14

# Boot file for PowerPC EFI
dhcp-boot=tag:efi-ppc64le-{{.Network.ClusterName}},tag:{{.Network.ClusterName}},grub2/grubppc64.efi